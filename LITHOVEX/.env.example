PORT=5000
NODE_ENV=development
DEFAULT_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# ── HuggingFace tokens (9 total — rotate on quota exhaustion) ─────────────────
# Token #1 is primary. When a model hits rate-limit, LITHOVEX rotates through
# all coding models on the same token, then advances to the next token.
HUGGINGFACE_API_KEY_1=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_2=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_3=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_4=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_5=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_6=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_7=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_8=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY_9=hf_xxxxxxxxxxxxxxxxxxxx

# ── GitHub OAuth (Device Flow — no redirect URL needed) ───────────────────────
# 1. Go to: github.com → Settings → Developer Settings → OAuth Apps → New App
# 2. Set Homepage URL to: http://localhost:5000
# 3. Leave Callback URL blank (Device Flow does not need it)
# 4. Copy the Client ID below
GITHUB_CLIENT_ID=Ov23lixxxxxxxxxxxxxxxxxx

# Optional: override SQLite DB path
# LITHOVEX_DB_PATH=/data/lithovex.db
